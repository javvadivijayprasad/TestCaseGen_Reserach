[
  {
    "id": "R-LOG-001",
    "domain": "logistics",
    "layer": "API",
    "category": "validation",
    "title": "Dispatcher creates shipment with valid dimensions",
    "statement": "An authenticated dispatcher shall be able to create a shipment with origin, destination, weight in (0, 50] kg and each dimension in (0, 200] cm. A shipment id and audit entry must be returned on success.",
    "actors": [
      "dispatcher"
    ],
    "preconditions": [
      "authenticated",
      "role:dispatcher"
    ],
    "triggers": [
      "dispatcher creates a shipment"
    ],
    "expected_outcomes": [
      "shipment is created with status created",
      "audit record written",
      "response 200 or 201 with shipment id"
    ],
    "error_pathways": [
      "400 on weight outside (0,50]",
      "400 on any dimension outside (0,200]",
      "400 on missing origin or destination",
      "401 if unauthenticated"
    ],
    "target_app": "logistics-app",
    "target_endpoint_or_screen": "/shipments"
  },
  {
    "id": "R-LOG-002",
    "domain": "logistics",
    "layer": "API",
    "category": "business_rule",
    "title": "Shipment rejected when origin equals destination",
